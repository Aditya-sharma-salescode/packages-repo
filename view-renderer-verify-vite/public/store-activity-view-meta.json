{
    "node_id": "store_activity",
    "node_label": "Store Activity",
    "node_logo": "",
    "node_description": "Select store-level activities and configure the data capture form for each. Use advanced settings to customize fields.",
    "node_type": "store_activity",
    "target_config_keys": [
        "app"
    ],
    "outlet_tab_blocklist": [
        "outletProfile",
        "taskRecommendations"
    ],
    "show_in_self_serve_home_page": "true",
    "preview": {
        "type": "pwa",
        "screen": "outlet_detail",
        "action": "preview_screen"
    },
    "children": [
        {
            "activity_id": "asset_tracking",
            "activity_label": "Asset Tracking",
            "activity_description": "Asset Tracking",
            "advance_settings_handler": "form-package",
            "activity_default": {
                "enabled": true,
                "strategies": {},
                "config": {
                    "formHeaderLabel": "Capture asset details accurately. Required fields are marked with *.",
                    "formHeaderVariant": "info",
                    "schema": {
                        "formName": "Asset Tracking",
                        "sections": [
                            {
                                "id": "at-new-asset",
                                "title": "New Asset",
                                "fields": [
                                    {
                                        "id": "assetImage",
                                        "type": "camera",
                                        "label": "Asset Image",
                                        "required": true,
                                        "columnName": "imageUrl",
                                        "apiKey": "",
                                        "allowCamera": true,
                                        "allowGallery": false,
                                        "hintText": "Capture the asset on-site — GPS is recorded automatically.",
                                        "captureLocationWithImage": true,
                                        "showLiveLocationTag": true,
                                        "linkedLatFieldId": "latitude",
                                        "linkedLngFieldId": "longitude"
                                    },
                                    {
                                        "id": "latitude",
                                        "type": "text",
                                        "label": "Latitude",
                                        "required": false,
                                        "columnName": "latitude",
                                        "apiKey": "lat",
                                        "apiType": "double",
                                        "condition": {
                                            "fieldId": "latitude",
                                            "operator": "equals",
                                            "value": "__never__"
                                        }
                                    },
                                    {
                                        "id": "longitude",
                                        "type": "text",
                                        "label": "Longitude",
                                        "required": false,
                                        "columnName": "longitude",
                                        "apiKey": "lng",
                                        "apiType": "double",
                                        "condition": {
                                            "fieldId": "longitude",
                                            "operator": "equals",
                                            "value": "__never__"
                                        }
                                    },
                                    {
                                        "id": "at-brand",
                                        "type": "text",
                                        "label": "Equipment Brand",
                                        "required": true,
                                        "columnName": "equipment_brand",
                                        "placeholder": "Enter equipment brand"
                                    },
                                    {
                                        "id": "at-equipment-number",
                                        "type": "text",
                                        "label": "Equipment Number",
                                        "required": true,
                                        "columnName": "equipment_number",
                                        "placeholder": "Enter equipment number"
                                    },
                                    {
                                        "id": "at-serial-number",
                                        "type": "text",
                                        "label": "Serial Number",
                                        "required": true,
                                        "columnName": "serial_number",
                                        "placeholder": "Enter serial number"
                                    },
                                    {
                                        "id": "at-cooler-category",
                                        "type": "dropdown",
                                        "label": "Cooler Category",
                                        "required": true,
                                        "columnName": "cooler_category",
                                        "options": [
                                            "Single Door Visi Cooler",
                                            "Double Door Visi Cooler",
                                            "Chest Freezer",
                                            "Deep Freezer",
                                            "Bottle Cooler"
                                        ]
                                    },
                                    {
                                        "id": "at-remarks",
                                        "type": "textarea",
                                        "label": "Remarks",
                                        "required": false,
                                        "columnName": "remarks",
                                        "placeholder": "Add any remarks"
                                    }
                                ]
                            }
                        ],
                        "meta": {
                            "submitLabel": "Submit",
                            "submitEndpoint": "/outlet-activities"
                        }
                    }
                },
                "services": {}
            },
            "outlet_activity_tab_default": {
                "id": "asset_tracking",
                "label": "ASSET TRACKING",
                "iconPath": "assets/svg/asset_tracking.svg",
                "isDefault": false,
                "themeColor": "#7B61FF",
                "storeInRequired": ""
            },
            "activity_form_activity_type_default": {
                "type": "asset_tracking",
                "display_name": "Asset Tracking",
                "enabled": true,
                "context_type": "outlet_activity"
            }
        },
