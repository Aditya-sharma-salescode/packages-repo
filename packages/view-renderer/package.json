    "@aditya-sharma-salescode/reports-setup": "^1.1.3",
    "@aditya-sharma-salescode/form-builder": "^1.2.3",
    "@aditya-sharma-salescode/shared-ui": "^1.0.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/lodash.merge": "^4.6.9"
