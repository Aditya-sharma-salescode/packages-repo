{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "paths": {
      "@/components/ui/*": ["../shared-ui/src/components/ui/*"],
      "@/lib/utils": ["../shared-ui/src/lib/utils"],
      "@/features/content-management/*": ["./src/*"],
      "@/features/content-management": ["./src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
